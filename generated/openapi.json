{
  "components": {
    "schemas": {
      "ErrorDetail": {
        "additionalProperties": false,
        "properties": {
          "location": {
            "description": "Where the error occurred, e.g. 'body.items[3].tags' or 'path.thing-id'",
            "type": "string"
          },
          "message": {
            "description": "Error message text",
            "type": "string"
          },
          "value": {
            "description": "The value at the given location"
          }
        },
        "type": "object"
      },
      "ErrorModel": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/ErrorModel.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "detail": {
            "description": "A human-readable explanation specific to this occurrence of the problem.",
            "examples": [
              "Property foo is required but is missing."
            ],
            "type": "string"
          },
          "errors": {
            "description": "Optional list of individual error details",
            "items": {
              "$ref": "#/components/schemas/ErrorDetail"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "instance": {
            "description": "A URI reference that identifies the specific occurrence of the problem.",
            "examples": [
              "https://example.com/error-log/abc123"
            ],
            "format": "uri",
            "type": "string"
          },
          "status": {
            "description": "HTTP status code",
            "examples": [
              400
            ],
            "format": "int64",
            "type": "integer"
          },
          "title": {
            "description": "A short, human-readable summary of the problem type. This value should not change between occurrences of the error.",
            "examples": [
              "Bad Request"
            ],
            "type": "string"
          },
          "type": {
            "default": "about:blank",
            "description": "A URI reference to human-readable documentation for the error.",
            "examples": [
              "https://example.com/errors/example"
            ],
            "format": "uri",
            "type": "string"
          }
        },
        "type": "object"
      },
      "PointOfInterest": {
        "additionalProperties": false,
        "properties": {
          "description": {
            "type": "string"
          },
          "icon_type": {
            "enum": [
              "trailhead",
              "parking",
              "campsite",
              "viewpoint",
              "water",
              "restroom",
              "picnic",
              "summit",
              "junction",
              "hazard",
              "historic",
              "general"
            ],
            "type": "string"
          },
          "image_url": {
            "type": "string"
          },
          "latitude": {
            "format": "double",
            "type": "number"
          },
          "longitude": {
            "format": "double",
            "type": "number"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "description",
          "latitude",
          "longitude",
          "icon_type"
        ],
        "type": "object"
      },
      "TrailGeometryOutputBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/TrailGeometryOutputBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "segments": {
            "items": {
              "$ref": "#/components/schemas/TrailSegment"
            },
            "type": [
              "array",
              "null"
            ]
          }
        },
        "required": [
          "segments"
        ],
        "type": "object"
      },
      "TrailListOutputBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/TrailListOutputBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "resources": {
            "description": "Names of available trails",
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          }
        },
        "required": [
          "resources"
        ],
        "type": "object"
      },
      "TrailOutput": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/TrailOutput.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "difficulty": {
            "enum": [
              "easy",
              "moderate",
              "hard"
            ],
            "type": "string"
          },
          "latitude": {
            "format": "double",
            "type": "number"
          },
          "length_miles": {
            "format": "double",
            "type": "number"
          },
          "longitude": {
            "format": "double",
            "type": "number"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "description",
          "length_miles",
          "difficulty",
          "latitude",
          "longitude"
        ],
        "type": "object"
      },
      "TrailPOIOutputBody": {
        "additionalProperties": false,
        "properties": {
          "$schema": {
            "description": "A URL to the JSON Schema for this object.",
            "examples": [
              "https://example.com/schemas/TrailPOIOutputBody.json"
            ],
            "format": "uri",
            "readOnly": true,
            "type": "string"
          },
          "pois": {
            "items": {
              "$ref": "#/components/schemas/PointOfInterest"
            },
            "type": [
              "array",
              "null"
            ]
          }
        },
        "required": [
          "pois"
        ],
        "type": "object"
      },
      "TrailSegment": {
        "additionalProperties": false,
        "properties": {
          "color": {
            "type": "string"
          },
          "coordinates": {
            "items": {
              "items": {
                "format": "double",
                "type": "number"
              },
              "maxItems": 2,
              "minItems": 2,
              "type": [
                "array",
                "null"
              ]
            },
            "type": [
              "array",
              "null"
            ]
          },
          "style": {
            "enum": [
              "solid",
              "dashed",
              "dotted"
            ],
            "type": "string"
          },
          "width": {
            "format": "double",
            "type": "number"
          }
        },
        "required": [
          "coordinates",
          "color",
          "style",
          "width"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Proud Trails API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/trail": {
      "get": {
        "operationId": "list-trails",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrailListOutputBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "List trails",
        "tags": [
          "Trails"
        ]
      }
    },
    "/trail/{name}": {
      "get": {
        "operationId": "get-trail",
        "parameters": [
          {
            "description": "Trail name",
            "in": "path",
            "name": "name",
            "required": true,
            "schema": {
              "description": "Trail name",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrailOutput"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Get trail metadata",
        "tags": [
          "Trails"
        ]
      }
    },
    "/trail/{name}/geometry": {
      "get": {
        "operationId": "get-trail-geometry",
        "parameters": [
          {
            "description": "Trail name",
            "in": "path",
            "name": "name",
            "required": true,
            "schema": {
              "description": "Trail name",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrailGeometryOutputBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Get trail line geometry",
        "tags": [
          "Trails"
        ]
      }
    },
    "/trail/{name}/pois": {
      "get": {
        "operationId": "get-trail-pois",
        "parameters": [
          {
            "description": "Trail name",
            "in": "path",
            "name": "name",
            "required": true,
            "schema": {
              "description": "Trail name",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TrailPOIOutputBody"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Get points of interest for a trail",
        "tags": [
          "Trails"
        ]
      }
    }
  }
}